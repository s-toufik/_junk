Here’s the final, fully OOP script where every node is a class, the agent uses composition, and everything leverages LangChain/LangGraph framework capabilities natively.

```python
"""
Fully async hexagonal agent using LangGraph + LangChain with OOP nodes,
composition, and in-memory checkpointing.

Every component is a class:
- Nodes: MemoryNode, OrchestrationNode, ToolExecutionNode, FinalNode
- Agent: composes nodes and builds the graph
- Ports: LLMPort, ToolPort, MemoryTrimmerPort (abstract)
- Adapters: concrete implementations using LangChain

Install:
    pip install langgraph langchain langchain-openai pydantic sqlglot
Set:
    export OPENAI_API_KEY=sk-...
"""

import asyncio
from abc import ABC, abstractmethod
from typing import List, Sequence, Literal, Annotated
from typing_extensions import TypedDict

from pydantic import BaseModel, Field
from langgraph.graph import StateGraph, END
from langgraph.checkpoint.memory import MemorySaver
from langgraph.prebuilt import ToolNode as LangGraphToolNode
from langgraph.graph.message import add_messages
from langchain_openai import ChatOpenAI
from langchain_core.tools import StructuredTool
from langchain_core.messages import (
    BaseMessage,
    HumanMessage,
    AIMessage,
    ToolMessage,
    trim_messages,
)
import sqlglot
import sqlite3

# ============================================================================
# 1. AGENT STATE (LangGraph standard)
# ============================================================================

class AgentState(TypedDict):
    messages: Annotated[Sequence[BaseMessage], add_messages]

# ============================================================================
# 2. PORTS (abstract interfaces, fully OOP)
# ============================================================================

class LLMPort(ABC):
    @abstractmethod
    async def ainvoke(self, messages: Sequence[BaseMessage], tools: List[dict]) -> AIMessage:
        ...

class ToolPort(ABC):
    @property
    @abstractmethod
    def name(self) -> str:
        ...

    @property
    @abstractmethod
    def description(self) -> str:
        ...

    @property
    @abstractmethod
    def langchain_tool(self) -> StructuredTool:
        ...

    @abstractmethod
    async def execute(self, args: dict) -> str:
        ...

class MemoryTrimmerPort(ABC):
    @abstractmethod
    async def trim(self, messages: Sequence[BaseMessage], max_tokens: int) -> Sequence[BaseMessage]:
        ...

# ============================================================================
# 3. ADAPTERS (concrete implementations)
# ============================================================================

class LangChainLLMAdapter(LLMPort):
    def __init__(self, model: str = "gpt-4o", temperature: float = 0.0):
        self._llm = ChatOpenAI(model=model, temperature=temperature)

    async def ainvoke(self, messages: Sequence[BaseMessage], tools: List[dict]) -> AIMessage:
        llm_with_tools = self._llm.bind_tools(tools)
        return await llm_with_tools.ainvoke(messages)

# ---------- Python Tool ----------
class PythonCodeInput(BaseModel):
    code: str = Field(..., description="Python code to execute")

class PythonExecutorTool(ToolPort):
    @property
    def name(self) -> str:
        return "python_executor"

    @property
    def description(self) -> str:
        return "Execute Python code. Input: 'code'."

    async def execute(self, args: dict) -> str:
        code = args.get("code", "")
        try:
            import io, contextlib, traceback
            stdout = io.StringIO()
            stderr = io.StringIO()
            with contextlib.redirect_stdout(stdout), contextlib.redirect_stderr(stderr):
                await asyncio.to_thread(exec, code, {"__builtins__": {}})
            out = stdout.getvalue()
            err = stderr.getvalue()
            return (out + ("\n[stderr]\n" + err if err else "")).strip() or "No output."
        except Exception:
            return traceback.format_exc()

    @property
    def langchain_tool(self) -> StructuredTool:
        async def _run(code: str) -> str:
            return await self.execute({"code": code})
        return StructuredTool.from_function(
            coroutine=_run,
            name=self.name,
            description=self.description,
            args_schema=PythonCodeInput,
        )

# ---------- SQL Tool (Oracle -> SQLite) ----------
class SQLQueryInput(BaseModel):
    query: str = Field(..., description="Oracle SQL query to execute")

class SQLExecutorTool(ToolPort):
    def __init__(self):
        self.conn = sqlite3.connect(":memory:")
        self.conn.row_factory = sqlite3.Row

    @property
    def name(self) -> str:
        return "sql_executor"

    @property
    def description(self) -> str:
        return "Execute an Oracle SQL statement. Input: 'query'."

    async def execute(self, args: dict) -> str:
        oracle_sql = args.get("query", "")
        try:
            sqlite_sql = sqlglot.transpile(oracle_sql, read="oracle", write="sqlite")[0]
        except Exception as e:
            return f"Transpilation error: {e}"
        try:
            cur = self.conn.cursor()
            cur.execute(sqlite_sql)
            if sqlite_sql.strip().upper().startswith("SELECT"):
                rows = cur.fetchall()
                if not rows:
                    return "No rows."
                headers = [d[0] for d in cur.description]
                result = [dict(zip(headers, r)) for r in rows]
                return str(result)
            else:
                self.conn.commit()
                return f"Done. Rows affected: {cur.rowcount}"
        except Exception as e:
            return f"Execution error: {e}"

    @property
    def langchain_tool(self) -> StructuredTool:
        async def _run(query: str) -> str:
            return await self.execute({"query": query})
        return StructuredTool.from_function(
            coroutine=_run,
            name=self.name,
            description=self.description,
            args_schema=SQLQueryInput,
        )

# ---------- Memory Trimmer ----------
def _token_counter(messages: Sequence[BaseMessage]) -> int:
    return sum(len(m.content) // 4 for m in messages if hasattr(m, "content") and m.content)

class LangChainMemoryTrimmer(MemoryTrimmerPort):
    def __init__(self, max_tokens: int = 2000):
        self.max_tokens = max_tokens

    async def trim(self, messages: Sequence[BaseMessage], max_tokens: int | None = None) -> Sequence[BaseMessage]:
        max_t = max_tokens or self.max_tokens
        return trim_messages(
            list(messages),
            max_tokens=max_t,
            token_counter=_token_counter,
            strategy="last",
            start_on="human",
            include_system=True,
        )

# ============================================================================
# 4. NODES (each is a class with an async __call__ method)
# ============================================================================

class Node(ABC):
    @abstractmethod
    async def __call__(self, state: AgentState) -> dict:
        """Process state and return a partial state update."""
        ...

class MemoryNode(Node):
    def __init__(self, trimmer: MemoryTrimmerPort, max_tokens: int = 2000):
        self._trimmer = trimmer
        self._max_tokens = max_tokens

    async def __call__(self, state: AgentState) -> dict:
        trimmed = await self._trimmer.trim(state["messages"], self._max_tokens)
        return {"messages": list(trimmed)}

class OrchestrationNode(Node):
    def __init__(self, llm: LLMPort, tool_schemas: List[dict]):
        self._llm = llm
        self._tool_schemas = tool_schemas

    async def __call__(self, state: AgentState) -> dict:
        ai_msg = await self._llm.ainvoke(state["messages"], self._tool_schemas)
        return {"messages": [ai_msg]}

class ToolExecutionNode(Node):
    def __init__(self, tools: List[ToolPort]):
        lc_tools = [tool.langchain_tool for tool in tools]
        self._tool_node = LangGraphToolNode(lc_tools)

    async def __call__(self, state: AgentState) -> dict:
        # LangGraph ToolNode is also an async callable returning dict
        return await self._tool_node(state)

class FinalNode(Node):
    async def __call__(self, state: AgentState) -> dict:
        # Nothing to do – the final answer is already in the messages
        return {}

# ============================================================================
# 5. AGENT CLASS (composition of nodes)
# ============================================================================

class Agent:
    def __init__(
        self,
        memory_node: MemoryNode,
        orchestration_node: OrchestrationNode,
        tool_node: ToolExecutionNode,
        final_node: FinalNode,
    ):
        self._memory_node = memory_node
        self._orchestration_node = orchestration_node
        self._tool_node = tool_node
        self._final_node = final_node

        self._graph = self._build_graph()

    def _build_graph(self):
        builder = StateGraph(AgentState)

        # Add nodes
        builder.add_node("memory", self._memory_node)
        builder.add_node("orchestration", self._orchestration_node)
        builder.add_node("tools", self._tool_node)
        builder.add_node("final", self._final_node)

        # Edges
        builder.set_entry_point("memory")
        builder.add_edge("memory", "orchestration")

        def route(state: AgentState) -> Literal["tools", "final"]:
            last_msg = state["messages"][-1]
            if isinstance(last_msg, AIMessage) and last_msg.tool_calls:
                return "tools"
            return "final"

        builder.add_conditional_edges("orchestration", route)
        builder.add_edge("tools", "memory")  # loop back after tool execution
        builder.add_edge("final", END)

        # In-memory checkpoint
        checkpointer = MemorySaver()
        return builder.compile(checkpointer=checkpointer)

    async def arun(self, user_input: str, thread_id: str = "1") -> Sequence[BaseMessage]:
        initial_state: AgentState = {"messages": [HumanMessage(content=user_input)]}
        config = {"configurable": {"thread_id": thread_id}}

        final_event = None
        async for event in self._graph.astream(initial_state, config=config, stream_mode="values"):
            final_event = event

        return final_event["messages"]

    async def astream(self, user_input: str, thread_id: str = "1"):
        initial_state: AgentState = {"messages": [HumanMessage(content=user_input)]}
        config = {"configurable": {"thread_id": thread_id}}

        async for event in self._graph.astream(initial_state, config=config, stream_mode="values"):
            yield event["messages"]

# ============================================================================
# 6. MAIN
# ============================================================================

async def main():
    # Instantiate adapters
    llm = LangChainLLMAdapter(model="gpt-4o", temperature=0.0)
    memory_trimmer = LangChainMemoryTrimmer(max_tokens=1500)

    python_tool = PythonExecutorTool()
    sql_tool = SQLExecutorTool()
    tools = [python_tool, sql_tool]

    # Tool schemas for bind_tools
    tool_schemas = [tool.langchain_tool.get_input_schema().model_json_schema() for tool in tools]

    # Instantiate nodes (composition)
    memory_node = MemoryNode(memory_trimmer, max_tokens=1500)
    orchestration_node = OrchestrationNode(llm, tool_schemas)
    tool_node = ToolExecutionNode(tools)
    final_node = FinalNode()

    # Compose the agent
    agent = Agent(
        memory_node=memory_node,
        orchestration_node=orchestration_node,
        tool_node=tool_node,
        final_node=final_node,
    )

    query = "Create a table employees (id, name), insert a row id=1 name='Alice', and query it."
    print("--- AGENT START ---")
    async for messages in agent.astream(query, thread_id="1"):
        last_msg = messages[-1]
        if isinstance(last_msg, AIMessage):
            tool_info = ""
            if last_msg.tool_calls:
                tool_info = f" [tool_calls: {[(tc['name'], tc['args']) for tc in last_msg.tool_calls]}]"
            print(f"assistant: {last_msg.content}{tool_info}")
        elif isinstance(last_msg, ToolMessage):
            print(f"tool ({last_msg.name}): {last_msg.content[:200]}...")
        elif isinstance(last_msg, HumanMessage):
            print(f"user: {last_msg.content}")
    print("--- AGENT END ---")

if __name__ == "__main__":
    asyncio.run(main())
```

---

Key OOP & Composition Features

· Every node is a class implementing the Node interface with an async __call__ method: MemoryNode, OrchestrationNode, ToolExecutionNode, FinalNode.
· Agent uses composition: it receives node instances in its constructor and builds the graph internally. No inheritance from the graph, no hard‑coded functions.
· Ports & adapters are abstract classes and concrete implementations, following hexagonal architecture strictly.
· LangChain native messages (HumanMessage, AIMessage, ToolMessage) are used everywhere – the state is a standard LangGraph TypedDict with add_messages.
· ToolNode (LangGraph built-in) is wrapped inside ToolExecutionNode, keeping framework integration but in an OOP wrapper.
· Checkpointing is handled by MemorySaver inside the Agent._build_graph() method.

Run the script after installing dependencies and setting your OpenAI key. The agent will autonomously create, insert, and query the employees table using the Oracle‑dialect SQL tool.